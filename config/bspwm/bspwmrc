#!/bin/sh

# ============================================================================
#  bspwmrc - Minimal & Clean bspwm configuration
#  LMDE 7 on MacBook Pro 2015
# ============================================================================

# ── Monitor & Desktops ─────────────────────────────────────────────────────
# Detect the primary monitor and assign 5 workspaces
bspc monitor -d 1 2 3 4 5

# ── Global Settings ────────────────────────────────────────────────────────
bspc config border_width          2
bspc config window_gap            12
bspc config split_ratio           0.52
bspc config borderless_monocle    true
bspc config gapless_monocle       true
bspc config single_monocle        false
bspc config paddingless_monocle   true

# ── Focus Behavior ─────────────────────────────────────────────────────────
bspc config focus_follows_pointer true
bspc config pointer_follows_focus false
bspc config pointer_modifier      mod4
bspc config pointer_action1       move
bspc config pointer_action2       resize_side

# ── Colors ─────────────────────────────────────────────────────────────────
bspc config normal_border_color   "#292e42"
bspc config active_border_color   "#292e42"
bspc config focused_border_color  "#7aa2f7"
bspc config urgent_border_color   "#f7768e"
bspc config presel_feedback_color "#7aa2f7"

# ── Rules ──────────────────────────────────────────────────────────────────
bspc rule -a Gimp desktop='^5' state=floating follow=on
bspc rule -a Firefox desktop='^2' follow=on
bspc rule -a Thunar desktop='^3' follow=on
bspc rule -a Pavucontrol state=floating
bspc rule -a Lxappearance state=floating
bspc rule -a Nm-connection-editor state=floating

# ── Autostart ──────────────────────────────────────────────────────────────

# Kill existing instances before restarting
pgrep -x sxhkd > /dev/null && pkill -x sxhkd
pgrep -x picom > /dev/null && pkill -x picom
pgrep -x dunst > /dev/null && pkill -x dunst

# Hotkey daemon
sxhkd &

# Compositor
picom --config "$HOME/.config/picom/picom.conf" &

# Notification daemon
dunst &

# Polybar
"$HOME/.config/polybar/launch.sh" &

# Wallpaper - solid dark color as fallback, or use feh for an image
if [ -f "$HOME/.config/bspwm/wallpaper.jpg" ]; then
    feh --bg-fill "$HOME/.config/bspwm/wallpaper.jpg"
elif [ -f "$HOME/.config/bspwm/wallpaper.png" ]; then
    feh --bg-fill "$HOME/.config/bspwm/wallpaper.png"
else
    # Solid dark background matching the color scheme
    hsetroot -solid "#1a1b26" 2>/dev/null || xsetroot -solid "#1a1b26"
fi

# Cursor
xsetroot -cursor_name left_ptr &

# Screen power management - disable blanking
xset s off &
xset -dpms &

# Keyboard repeat rate (useful for vim-style navigation)
xset r rate 300 50 &
